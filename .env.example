# Project Sauron — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git

# Grafana
GRAFANA_ADMIN_PASSWORD=change_me_strong_password

# AWS credentials for CloudWatch Exporter
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# EC2 public IP (used in Grafana root URL)
EC2_PUBLIC_IP=your.ec2.public.ip

# GitHub Actions secrets (set in repo Settings > Secrets, not here)
# EC2_HOST=your.ec2.public.ip
# EC2_SSH_KEY=<contents of your EC2 private key>
# EC2_USER=ec2-user

# Monitoring stack configuration
DOMAIN=your.domain.com                    # e.g. sauron.7ports.ca
CERTBOT_EMAIL=your@email.com              # e.g. raj@7ports.ca

# Per-client bearer tokens for push endpoint authentication
# Generate each with: openssl rand -base64 32
PUSH_BEARER_TOKEN_SAURON=                 # Token for sauron self-monitoring
# PUSH_BEARER_TOKEN_<CLIENT_NAME>=        # Add one per client project

# Loki retention
LOKI_RETENTION_HOURS=168                  # 7 days

# Grafana Alloy — self-monitoring agent (used by monitoring/alloy/config.alloy)
# These are consumed by the Alloy container at runtime via env() calls in River syntax.
SAURON_METRICS_URL=https://sauron.7ports.ca/metrics/push  # Prometheus remote-write endpoint
SAURON_LOKI_URL=https://sauron.7ports.ca/loki/api/v1/push # Loki push endpoint
CLIENT_NAME=sauron                                         # Label applied to all metrics/logs
CLIENT_ENV=production                                      # Label applied to all metrics/logs
# PUSH_BEARER_TOKEN_SAURON is already defined above — Alloy reuses the same token
