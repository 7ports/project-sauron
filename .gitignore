.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# SSH keys
*.pem
*.key
id_rsa*
id_ed25519*

# Jekyll build output
docs/_site/
docs/.jekyll-cache/
docs/.jekyll-metadata

# Node (for any tooling scripts)
node_modules/
